  </div>
</section>
 
<div class="next-steps">
  <h3>What happens next</h3>
  <div class="steps-row">
    <div class="step-card">
      <div class="step-num">01</div>
      <p>Submit your info above</p>
    </div>
    <div class="step-card">
      <div class="step-num">02</div>
      <p>Check your inbox — your exclusive offer link arrives immediately</p>
    </div>
    <div class="step-card">
      <div class="step-num">03</div>
      <p>Choose your program and enroll at your graduate rate</p>
    </div>
  </div>
</div>
 
<footer>
  © 2026 Transform Strong · <a href="https://transformstronger.com" style="color:inherit;">transformstronger.com</a>
</footer>
 
</body>
</html>
